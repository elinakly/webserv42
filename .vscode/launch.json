{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug webserv",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/webserv",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "build",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set GDB to stop on shared library events",
          "text": "set stop-on-solib-events off",
          "ignoreFailures": true
        }
      ],
      "logging": {
        "engineLogging": false
      }
    },
    {
      "name": "Attach to webserv",
      "type": "cppdbg",
      "request": "attach",
      "program": "${workspaceFolder}/webserv",
      "processId": "${command:pickProcess}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
